PORT=3001
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_NAME=doctor_barbearia
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

JWT_SECRET=troque_por_um_segredo_forte

ZAPI_INSTANCE=sua_instancia
ZAPI_TOKEN=seu_token
ZAPI_CLIENT_TOKEN=seu_client_token

PAGSEGURO_TOKEN=seu_token_pagseg
PAGSEGURO_WEBHOOK_SECRET=troque_por_um_segredo_forte

API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_AUTH_MAX=20

# SaaS / Asaas (gateway de pagamento para planos mensais)
# Crie conta em https://www.asaas.com/ → API → gerar token
ASAAS_ENV=sandbox
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=troque_por_um_segredo_forte

# Multi-tenant (white-label)
# Cada cliente do SaaS tem seu próprio subdomínio (ex: doctor.app.com).
# Configure BASE_DOMAIN (ex: doctorbarbearia.com) e o slug do tenant padrão.
BASE_DOMAIN=localhost:3000
DEFAULT_TENANT_SLUG=doctor

# Branding padrão (cores da barbearia — exibidas no PWA e app Android)
BRAND_NAME=Doctor Barbearia
BRAND_GOLD=#C9A84C
BRAND_BG=#060606
BRAND_WHATSAPP=5512982671917
BRAND_LOGO_URL=
